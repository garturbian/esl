<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or "ESL Adventures" }} | Learn English</title>
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap" rel="stylesheet">
</head>
<body class="{{ 'page-home' if page.url == '/' }}">
    <div class="container">
        <header>
            <a href="{{ '/' | url }}" style="text-decoration: none;"><div class="site-title text-gradient">ESL Learning</div></a>
            <nav>
                <ul>
                    <li><a href="{{ '/' | url }}"><span class="nav-icon">🏠</span><span>Home</span></a></li>
                    <li><a href="{{ '/lessons/' | url }}"><span class="nav-icon">📚</span><span>Lessons</span></a></li>
                </ul>
            </nav>
        </header>

        <main>
            {% if title %}
                <h1 class="text-gradient">{{ title }}</h1>
            {% endif %}
            
            <div class="content">
                {% if audio %}
                <div class="audio-container">
                    <audio controls>
                        <source src="{{ audio | url }}" type="audio/mpeg">
                        Your browser does not support the audio element.
                    </audio>
                </div>
                {% endif %}
                {{ content | safe }}
            </div>
        </main>

        <footer>
            <p>&copy; {% year %} &bull; Built with Eleventy for ESL Students</p>
        </footer>
    </div>
</body>
</html>